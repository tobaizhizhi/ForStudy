# paywalled-service 配置模板。复制成 .env 按需填。.env 不要提交。
# 只用测试网私钥，绝不要用主网私钥。

# --- 链 / facilitator（默认即可）---
RPC_URL=https://sepolia.base.org
FACILITATOR_URL=https://x402.org/facilitator
PORT=41207

# --- server 收款地址（卖服务收 USDC 到这里，建议填你的测试钱包）---
PAY_TO=0x0000000000000000000000000000000000000000
PRICE=$0.001

# --- client 付款钱包（只有 start:client 需要）---
# 一个有 Base Sepolia 测网 USDC 的测试钱包私钥。
# 领测网 USDC：https://faucet.circle.com （选 Base Sepolia）
CLIENT_PRIVATE_KEY=
