# agent-network 配置模板。复制成 .env 按需覆盖。.env 不要提交。
# 全部可留空——默认值就能在 Base Sepolia 公共 RPC 上跑（只读、无私钥、无 API key）。

# --- RPC（只读公共 Base Sepolia）---
RPC_URL=https://sepolia.base.org

# --- 端口 ---
MCP_PORT=41241
A2A_PORT=41242

# --- MCP / A2A 地址（本机默认即可）---
# MCP_URL=http://localhost:41241/mcp
# A2A_BASE_URL=http://localhost:41242

# --- Signed Agent Card 开关 ---
# 默认签名。设为 false 可演示“未签名卡被 client 拒绝”。
# SIGN_AGENT_CARD=false

# --- 演示查询地址 ---
# DEMO_ADDRESS=0x...
