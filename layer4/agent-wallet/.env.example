# Layer 4 Agent 钱包脚本配置模板。复制成 .env，填真实值。.env 不要提交。

# --- RPC ---
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# --- Pimlico（bundler + paymaster）---
# 去 https://dashboard.pimlico.io 建一个 project，拿 API key。
# 只放做了额度/域名限制的 key；这把 key 会决定谁替你付 gas，别泄露。
PIMLICO_API_KEY=

# --- 密钥（只用测试网钱包，不要用主网私钥）---
# owner 是人类，账户的 root。
OWNER_PRIVATE_KEY=
# agent 的 session key（可选，session-key 脚本会用；不填则脚本自动生成一把）。
AGENT_PRIVATE_KEY=

# --- Layer 2 合约（来自 layer2/deployments/base-sepolia.md）---
ESCROW_ADDRESS=
TOKEN_ADDRESS=

# --- 自定义账户（选修模块 07 部署后的 AgentSmartAccount 地址，用于 session-key 脚本）---
AGENT_SMART_ACCOUNT_ADDRESS=
